---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.bg-grid{position:fixed;inset:0;z-index:0;background-image:linear-gradient(#232d3b 1px,transparent 1px),linear-gradient(90deg,#232d3b 1px,transparent 1px);background-size:64px 64px;opacity:.10;pointer-events:none;-webkit-mask-image:radial-gradient(ellipse 90% 50% at 50% 0%,#000 20%,transparent 80%);mask-image:radial-gradient(ellipse 90% 50% at 50% 0%,#000 20%,transparent 80%);}
			main{width:100%;max-width:1120px;margin:0 auto;padding:0 28px;position:relative;z-index:2;}
			.head{padding:70px 0 30px;}
			.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#e0a53d;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
			.eyebrow::before{content:"";width:26px;height:1px;background:#8a6f3a;}
			.head h1{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(1.9rem,4vw,2.8rem);line-height:1.1;letter-spacing:-.02em;margin:0;color:#e6edf5;}
			.posts{padding:20px 0 90px;}
			.post-list{display:flex;flex-direction:column;gap:1px;background:#232d3b;border:1px solid #232d3b;list-style:none;margin:0;padding:0;}
			.post-item{margin:0;width:100%;}
			.post{display:block;background:#111823;padding:30px 34px;transition:background .25s;position:relative;overflow:hidden;text-decoration:none;}
			.post::after{content:"";position:absolute;left:0;top:0;height:100%;width:2px;background:#5b8dc7;transform:scaleY(0);transition:transform .3s;transform-origin:top;}
			.post:hover{background:#161e2b;}
			.post:hover::after{transform:scaleY(1);}
			.post .date{font-family:'JetBrains Mono',monospace;font-size:12px;color:#5f6b7c;letter-spacing:.03em;margin:0 0 10px;}
			.post .title{font-family:'Space Grotesk',sans-serif;font-size:1.4rem;font-weight:600;margin:0 0 10px;line-height:1.25;color:#e6edf5;}
			.post .desc{color:#9aa8ba;font-size:.98rem;max-width:70ch;margin:0 0 14px;}
			.post .more{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:#7db0e8;letter-spacing:.03em;}
		</style>
	</head>
	<body>
		<div class="bg-grid"></div>
		<Header />
		<main>
			<section class="head">
				<div class="eyebrow">All posts</div>
				<h1>Write-ups &amp; notes</h1>
			</section>
			<section class="posts">
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-item">
							<a class="post" href={`/blog/${post.id}/`}>
								<div class="date"><FormattedDate date={post.data.pubDate} /></div>
								<h4 class="title">{post.data.title}</h4>
								<p class="desc">{post.data.description}</p>
								<span class="more">Read the post &rarr;</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
