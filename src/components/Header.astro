---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header style="background:#0d1117;">
	<nav>
		<div class="brand">
			<a href="/" class="brand-inner">
				<span class="mark">JO</span>
				<span class="brand-text"><b>{SITE_TITLE}</b><span class="sub">BLOG</span></span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Posts</HeaderLink>
			<a href="https://opperman.dev">Portfolio</a>
			<a href="https://cv.opperman.dev">CV</a>
		</div>
		<div class="social-links">
			<a href="https://github.com/Johan-Opperman" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header{margin:0;padding:0 1.5em;background:#0d1117;border-bottom:1px solid #232d3b;position:sticky;top:0;z-index:50;}
	nav{display:flex;align-items:center;justify-content:space-between;max-width:1120px;margin:0 auto;height:66px;}
	.brand-inner{display:flex;align-items:center;gap:12px;text-decoration:none;font-family:'Space Grotesk',sans-serif;}
	.mark{width:30px;height:30px;border:1.5px solid #5b8dc7;display:grid;place-items:center;position:relative;color:#7db0e8;font-size:13px;font-family:'JetBrains Mono',monospace;}
	.mark::before,.mark::after{content:"";position:absolute;width:6px;height:6px;border:1.5px solid #e0a53d;}
	.mark::before{top:-4px;left:-4px;border-right:none;border-bottom:none;}
	.mark::after{bottom:-4px;right:-4px;border-left:none;border-top:none;}
	.brand-text{display:flex;flex-direction:column;line-height:1.15;align-items:flex-start;}
	.brand-text b{font-size:16px;color:#e6edf5;font-weight:700;display:block;}
	.brand-text .sub{display:block;}
	.brand-text .sub{font-size:11px;color:#9aa8ba;font-family:'JetBrains Mono',monospace;letter-spacing:.05em;font-weight:400;}
	.internal-links{display:flex;gap:8px;align-items:center;}
	nav a{padding:8px 12px;color:#9aa8ba;border-bottom:none;text-decoration:none;font-size:13.5px;font-weight:500;transition:color .2s;}
	.internal-links a:hover{color:#e6edf5;}
	nav a.active{color:#7db0e8;text-decoration:none;}
	.social-links,.social-links a{display:flex;}
	.social-links a{color:#9aa8ba;transition:color .2s;}
	.social-links a:hover{color:#7db0e8;}
	@media (max-width:720px){.social-links{display:none}.internal-links{gap:2px}nav a{padding:6px 8px;font-size:12px}}
</style>
