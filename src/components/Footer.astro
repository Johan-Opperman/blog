---
const today = new Date();
---

<footer>
	<div class="foot-inner">
		<div class="brand">
			<span class="mark">JO</span>
			<b>Johan Opperman</b>
		</div>
		<p>&copy; {today.getFullYear()} Johan Opperman &middot; Western Cape</p>
		<div class="foot-links">
			<a href="https://opperman.dev">Portfolio</a>
			<a href="https://cv.opperman.dev">CV</a>
		</div>
	</div>
</footer>
<style>
	footer{padding:40px 1.5em;background:#0d1117;border-top:1px solid #232d3b;color:#5f6b7c;}
	.foot-inner{max-width:1120px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:18px;}
	.brand{display:flex;align-items:center;gap:12px;font-family:'Space Grotesk',sans-serif;}
	.brand b{font-size:15px;color:#e6edf5;font-weight:700;}
	.mark{width:28px;height:28px;flex-shrink:0;box-sizing:border-box;border:1.5px solid #5b8dc7;display:grid;place-items:center;position:relative;color:#7db0e8;font-size:12px;font-family:'JetBrains Mono',monospace;}
	.mark::before,.mark::after{content:"";position:absolute;width:5px;height:5px;border:1.5px solid #e0a53d;}
	.mark::before{top:-4px;left:-4px;border-right:none;border-bottom:none;}
	.mark::after{bottom:-4px;right:-4px;border-left:none;border-top:none;}
	footer p{font-family:'JetBrains Mono',monospace;font-size:12px;color:#5f6b7c;margin:0;}
	.foot-links{display:flex;gap:22px;}
	.foot-links a{font-size:13px;color:#9aa8ba;text-decoration:none;transition:color .2s;}
	.foot-links a:hover{color:#7db0e8;}
	@media(max-width:520px){.foot-inner{flex-direction:column;text-align:center;gap:14px}}
</style>
